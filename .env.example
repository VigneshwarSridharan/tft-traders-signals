# Copy to .env and fill in real values. Never commit .env.

# --- API ---
NODE_ENV=development
PORT=3000

# Postgres connection string
DATABASE_URL=postgresql://tft:tft@localhost:5432/tft_traders_signals

# Redis connection string (queue + cache)
REDIS_URL=redis://localhost:6379

# Public tracking domain (pixel + click redirects are served from here).
# Must match Caddy's TRACKING_HOST (docker-compose.yml), which defaults to
# track.localhost for local dev — override both to a real subdomain of your
# sending domain in production.
TRACKING_DOMAIN=track.localhost

# 32+ char random key used to encrypt Zoho app passwords at rest.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=change-me-to-a-random-32-plus-character-secret

# Dashboard origin, used for CORS. Matches Caddy's DASHBOARD_HOST
# (docker-compose.yml), which defaults to dashboard.localhost for local dev.
WEB_APP_URL=https://dashboard.localhost

# 32+ char random secret used to sign access-token JWTs.
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=change-me-to-a-random-32-plus-character-secret
# Access token lifetime (jsonwebtoken "expiresIn" format)
JWT_ACCESS_TTL=15m
# Refresh token (session) lifetime, in days
REFRESH_TOKEN_TTL_DAYS=30
# How long an invitation link stays valid, in hours
INVITATION_TTL_HOURS=72

# Local directory (volume-backed) where compose attachments are stored
ATTACHMENT_STORAGE_PATH=./storage/attachments

# Domain used to synthesize the RFC 5322 Message-ID header for outbound mail
SEND_FROM_DOMAIN=track.localhost

# Optional path to a MaxMind GeoLite2 City .mmdb file, used for coarse
# open/click geolocation (country/city). Requires a free MaxMind account:
# https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# Leave unset to disable geo enrichment (tracking still works, without geo).
GEOLITE2_CITY_DB_PATH=

# Clicks recorded fewer than this many seconds after send are flagged as bot
# traffic (security-scanner prefetch) and excluded from headline metrics.
TRACKING_CLICK_BOT_MIN_SECONDS=3

# Per-IP rate limit for the public tracking endpoints (pixel + click
# redirect): at most this many events are enqueued per IP per window. The
# pixel/redirect response itself is never blocked, only event recording.
TRACKING_RATE_LIMIT_MAX=120
TRACKING_RATE_LIMIT_WINDOW_MS=60000

# How often the inbound worker polls each active sender account's mailbox
# over IMAP for bounces/replies, in milliseconds.
INBOUND_POLL_INTERVAL_MS=120000

# How often the "assume delivered" heuristic job runs, in milliseconds.
DELIVERY_HEURISTIC_POLL_INTERVAL_MS=900000
# A `sent` message with no bounce after this many hours is marked `delivered`.
DELIVERY_HEURISTIC_HOURS=48

# A single hard bounce suppresses an address immediately. This many soft
# bounces within the trailing window (days) also suppresses it.
SOFT_BOUNCE_SUPPRESSION_THRESHOLD=3
SOFT_BOUNCE_SUPPRESSION_WINDOW_DAYS=30

# Seed script (npm run db:seed --workspace apps/api): optional overrides for
# the first admin user. If SEED_ADMIN_PASSWORD is left unset, a random one is
# generated and printed once.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# Per-API-key request budget for the public REST API (/v1/*): at most this
# many requests are allowed per key per window.
PUBLIC_API_RATE_LIMIT_MAX=300
PUBLIC_API_RATE_LIMIT_WINDOW_MS=60000

# A webhook endpoint is automatically disabled (is_active=false) after this
# many consecutive failed deliveries. An admin notification is sent and it
# can be manually re-enabled from the Webhooks page once fixed.
WEBHOOK_AUTO_DISABLE_THRESHOLD=10

# How often the worker scans for due report subscriptions (Reports >
# Subscriptions), in milliseconds.
REPORT_SUBSCRIPTION_POLL_INTERVAL_MS=3600000

# Port the worker process listens on for its own /health readiness check
# (the worker has no other HTTP surface — see docker-compose.yml).
WORKER_HEALTH_PORT=3002

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Optional Sentry DSN for the api + worker processes. Leave unset to disable
# error tracking entirely (the default — no Sentry account required).
SENTRY_DSN=
# Fraction of transactions to sample for performance tracing (0-1).
SENTRY_TRACES_SAMPLE_RATE=0

# --- Web dashboard ---
# Same-origin path, proxied to the api container by Caddy (see
# docker/caddy/Caddyfile) — keeps auth cookies first-party instead of
# cross-site, which modern browsers' third-party-cookie blocking breaks.
NEXT_PUBLIC_API_URL=/api

# Optional Sentry DSN for the dashboard (client + server + edge runtimes).
# Sentry DSNs are meant to be public (they identify a project, not a secret),
# so this is safe to expose via NEXT_PUBLIC_. Leave unset to disable.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# Set these three (all optional) only if you also want build-time source-map
# upload to Sentry — without SENTRY_AUTH_TOKEN it's skipped automatically.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
